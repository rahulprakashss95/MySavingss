{
  "cli": {
    "version": ">= 7.5.0"
  },
  "build": {
    "release": {
      "cache": {
        "key": "release-v1",
        "cacheDefaultBranch": true
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "large"
      },
      "ios": {
        "simulator": false
      }
    },
    "development": {
      "developmentClient": false,
      "distribution": "internal",
      "cache": {
        "key": "dev-v1",
        "cacheDefaultBranch": true
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "large"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "cache": {
        "key": "preview-v1",
        "cacheDefaultBranch": true
      },
      "android": {
        "resourceClass": "large"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "cache": {
        "key": "prod-v1",
        "cacheDefaultBranch": true
      },
      "android": {
        "resourceClass": "large"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {}
  }
}
