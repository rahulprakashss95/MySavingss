{
  "name": "homevault",
  "version": "1.2.102",
  "homepage": "/HomeVault/",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "run-android": "npx expo run:android",
    "build-apk": "eas build -p android --profile development",
    "build-apk-local": "eas build --platform android --profile preview --local",
    "build-ios": "eas build -p ios --profile development",
    "build-web": "node scripts/gen-version.js && expo export --platform web && node scripts/patch-pwa.js",
    "deploy": "node scripts/deploy.js",
    "lint": "npx eslint \"src/**\"",
    "lint:fix": "npx eslint \"src/**\" --fix"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.6",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@reduxjs/toolkit": "^2.12.0",
    "@supabase/supabase-js": "^2.109.0",
    "@types/react": "~19.2.10",
    "axios": "^1.6.8",
    "expo": "^57.0.7",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-image-picker": "~57.0.5",
    "expo-linking": "~57.0.3",
    "expo-local-authentication": "~57.0.1",
    "expo-router": "~57.0.7",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "gh-pages": "^6.1.1",
    "moment": "^2.30.1",
    "nativewind": "4.1.23",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-inappbrowser-reborn": "^3.7.0",
    "react-native-modal-datetime-picker": "^17.1.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-toast-message": "^2.2.0",
    "react-native-url-polyfill": "^4.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "react-redux": "^9.3.0",
    "typescript": "~6.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "babel-preset-expo": "~57.0.0",
    "tailwindcss": "^3.4.19"
  },
  "private": true
}
